<section class="newsletter">
  <div class="container">
    <h2>{{ section.settings.heading }}</h2>

    <form method="post">
      <input type="email" placeholder="Enter email">
      <button type="submit">Subscribe</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ]
}
{% endschema %}