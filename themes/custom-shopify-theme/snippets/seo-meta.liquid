<title>
  {% if page_title %}
    {{ page_title }}
  {% else %}
    {{ shop.name }}
  {% endif %}
</title>

<meta name="description" content="{{ page_description | escape }}">

<meta property="og:title" content="{{ page_title }}">
<meta property="og:description" content="{{ page_description }}">
<meta property="og:site_name" content="{{ shop.name }}">